    g.trail_profit_threshold = 0.50    # 浮盈超过50%启用
    g.trail_stop_half = 0.08           # 自高点回撤8% → 减仓50%
    g.trail_stop_full = 0.12           # 自高点回撤12% → 清仓

    # ==================== trade2at4at5 动量排序（与 ta2 相同） ====================
    g.momentum_factor_yesterday = 1    # 昨日涨跌幅权重：涨1%=+1分
    g.momentum_factor_today = 0          # 今日涨跌幅权重：涨1%=+1分

    # ==================== tb4 EMA10 回踩加分 ====================
    g.ema_touch_lookback = 10            # 近 N 日检测 EMA10 触及
    g.ema_touch_bonus_above = 2          # 触及且收在 EMA10 线上
    g.ema_touch_bonus_below = 1          # 触及但收在 EMA10 线下

    # ==================== 状态变量 ====================
