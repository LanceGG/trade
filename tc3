def _stock_label(stock):
    info = get_security_info(stock)
    name = info.display_name if info else stock
    return f"{name}({stock.split('.')[0]})"


def _hold_days(stock, context):
    info = g.buy_info.get(stock, {})
    bd = info.get('buy_date')
    if bd is None:
        return -1
    return (context.current_dt.date() - bd.date()).days


def _log_trade(action, stock, context, reason, pnl_ratio=None, extra=''):
    """统一交易流水，便于回测后按原因聚合"""
    label = _stock_label(stock)
    hold = _hold_days(stock, context)
    info = g.buy_info.get(stock, {})
    pnl_str = f"{pnl_ratio*100:+.1f}%" if pnl_ratio is not None else ""
    log.info(f"[{action}] {label} {pnl_str} | 原因:{reason} | "
             f"选入:{info.get('setup', '')} | 持仓{hold}天 | "
             f"买入分{info.get('score', '')} | {extra}")
    if action in ('SELL', 'HALF_SELL'):
        g._daily_sells.append((stock, reason, pnl_ratio))
    elif action == 'BUY':
        g._daily_buys.append((stock, info.get('score', ''), info.get('setup', '')))


def _explain_stop_threshold(stock, context, market_score):
    hard = g.hard_stop
    bear = market_score < g.hard_stop_score_threshold
    after_bear = min(hard, g.hard_stop_tight) if bear else hard
    atr_pct = _calc_atr_stop_pct(stock, context)
    atr_part = g.atr_stop_mult * atr_pct if atr_pct is not None else None
    threshold = after_bear
    if atr_part is not None:
        threshold = max(threshold, atr_part)
    return threshold, {
        'hard': hard, 'bear': bear, 'after_bear': after_bear,
        'atr_pct': atr_pct, 'atr_part': atr_part, 'final': threshold
    }


def _log_stop_threshold(stock, context, market_score, label=''):
    threshold, d = _explain_stop_threshold(stock, context, market_score)
    atr_str = f"{d['atr_pct']*100:.1f}%" if d['atr_pct'] is not None else 'N/A'
    atr_final = f"{d['atr_part']*100:.1f}%" if d['atr_part'] is not None else 'N/A'
    log.info(f"[止损阈{label}] {_stock_label(stock)} hard={d['hard']:.0%} "
             f"熊市={d['bear']} bear后={d['after_bear']:.0%} "
             f"atr14={atr_str} 2xatr={atr_final} → 最终{-threshold*100:.1f}%")
    return threshold


def _log_position_inspect(stock, position, current_price, pnl_ratio, market_score, context, label='10:00'):
    if not g.analysis_log:
        return
    threshold = _explain_stop_threshold(stock, context, market_score)[0]
    peak = g.position_high.get(stock, current_price)
    dd_peak = (current_price - peak) / peak if peak > 0 else 0
    log.info(f"[巡检{label}] {_stock_label(stock)} 成本{position.avg_cost:.2f} "
             f"现价{current_price:.2f} 浮盈{pnl_ratio*100:+.1f}% "
             f"止损阈{-threshold*100:.1f}% 距止损{(pnl_ratio+threshold)*100:+.1f}% "
             f"通道{g.break_upper_count.get(stock, 0)}天 "
             f"高点{peak:.2f} 高点回撤{dd_peak*100:+.1f}% "
             f"已减半{g.trail_half_done.get(stock, False)} 持仓{_hold_days(stock, context)}天")


def _log_trail_status(stock, current_price, pnl_ratio, label=''):
    if not g.analysis_log:
        return
    peak = g.position_high.get(stock, current_price)
    if peak <= 0:
        return
    dd = (current_price - peak) / peak
    half_done = g.trail_half_done.get(stock, False)
    if pnl_ratio <= g.trail_profit_threshold:
        if pnl_ratio >= g.trail_profit_threshold - 0.10:
            log.info(f"[跟踪待机{label}] {_stock_label(stock)} 浮盈{pnl_ratio*100:+.1f}% "
                     f"未达{g.trail_profit_threshold:.0%}门槛 高点{peak:.2f}")
        return
    if dd <= -g.trail_stop_full:
        return  # 触发卖出，由 _log_trade 记录
    if dd <= -g.trail_stop_half:
        if half_done:
            log.info(f"[跟踪跳过{label}] {_stock_label(stock)} 已减半 浮盈{pnl_ratio*100:+.1f}% "
                     f"高点回撤{abs(dd*100):.1f}% 距清仓还差{(g.trail_stop_full-abs(dd))*100:.1f}%")
        return
    if dd <= -0.05:
        log.info(f"[跟踪预警{label}] {_stock_label(stock)} 浮盈{pnl_ratio*100:+.1f}% "
                 f"高点{peak:.2f} 回撤{abs(dd*100):.1f}% "
                 f"距减半{(g.trail_stop_half-abs(dd))*100:.1f}% 距清仓{(g.trail_stop_full-abs(dd))*100:.1f}%")


def _calc_atr_stop_pct(stock, context):
    try:
        hist = attribute_history(stock, 30, '1d', ['high', 'low', 'close'], skip_paused=True, df=False)
        if len(hist['close']) < 15:
            return None
        atr = talib.ATR(hist['high'], hist['low'], hist['close'], timeperiod=14)[-1]
        if not np.isfinite(atr) or hist['close'][-1] <= 0:
            return None
        return float(atr / hist['close'][-1])
    except Exception:
        return None


def _get_stop_threshold(stock, context, market_score):
    return _explain_stop_threshold(stock, context, market_score)[0]


def _update_position_high(stock, price):
    if price <= 0 or not np.isfinite(price):
        return
    prev = g.position_high.get(stock, price)
    g.position_high[stock] = max(prev, price)


def _cleanup_position_state(stock):
    g.sold_today.add(stock)
    g.buy_info.pop(stock, None)
    g.break_upper_count.pop(stock, None)
    g.position_high.pop(stock, None)
    g.trail_half_done.pop(stock, None)


def _check_profit_trailing(stock, current_price, pnl_ratio, label=''):
    """浮盈>50%时：高点回撤8%减仓50%，回撤12%清仓。返回 'full' / 'half' / None"""
    _update_position_high(stock, current_price)
    _log_trail_status(stock, current_price, pnl_ratio, label)
    if pnl_ratio <= g.trail_profit_threshold:
        return None
    peak = g.position_high.get(stock, current_price)
    if peak <= 0:
        return None
    dd_from_peak = (current_price - peak) / peak
    if dd_from_peak <= -g.trail_stop_full:
        return 'full'
    if dd_from_peak <= -g.trail_stop_half and not g.trail_half_done.get(stock, False):
        return 'half'
    return None


def _apply_profit_trailing(stock, position, current_price, pnl_ratio, context, label=''):
    peak = g.position_high.get(stock, current_price)
    dd = (current_price - peak) / peak if peak > 0 else 0
    action = _check_profit_trailing(stock, current_price, pnl_ratio, label)
    if action == 'full':
        _safe_order_target_value(stock, 0, current_price, 'sell', context)
        _log_trade('SELL', stock, context, f'盈利回撤清仓-{abs(dd*100):.1f}%',
                   pnl_ratio, f"高点{peak:.2f} 浮盈{pnl_ratio*100:+.1f}%")
        _cleanup_position_state(stock)
        return True
    if action == 'half':
        target_value = position.value * 0.5
        _safe_order_target_value(stock, target_value, current_price, 'sell', context)
        g.trail_half_done[stock] = True
        _log_trade('HALF_SELL', stock, context, f'盈利回撤减半-{abs(dd*100):.1f}%',
                   pnl_ratio, f"高点{peak:.2f} 目标市值{target_value:.0f}")
        return True
    return False


def _get_pre_close(stock, context):
    """获取昨收价（聚宽 current_data 无 pre_close 字段）"""
    try:
        hist = attribute_history(stock, 1, '1d', ['close'], skip_paused=True, df=False)
        if len(hist['close']) >= 1:
            pc = hist['close'][-1]
            if np.isfinite(pc) and pc > 0:
                return float(pc)
    except Exception:
        pass
    return None


def _get_yesterday_return_pct(stock, context):
    """昨日涨跌幅（百分点），涨1%返回+1"""
    try:
        hist = attribute_history(stock, 2, '1d', ['close'], skip_paused=True, df=False)
        if len(hist['close']) < 2 or hist['close'][-2] <= 0:
            return 0.0
        return float((hist['close'][-1] / hist['close'][-2] - 1) * 100)
    except Exception:
        return 0.0


def _get_today_return_pct(stock, context):
    """今日涨跌幅（百分点），涨1%返回+1；10:00用现价，盘前用开盘价"""
    pre_close = _get_pre_close(stock, context)
    if pre_close is None:
        return 0.0
    try:
        cd = get_current_data()[stock]
        price = cd.last_price
        if not np.isfinite(price) or price <= 0:
            price = cd.day_open
        if np.isfinite(price) and price > 0:
            return float((price - pre_close) / pre_close * 100)
    except Exception:
        pass
    return 0.0


def _get_ema10_touch_bonus(stock, context):
    """近 N 日内任意一天触及 EMA10：收线上+2，收线下+1（取最高档）"""
    try:
        need = g.ema_touch_lookback + 12
        hist = attribute_history(stock, need, '1d', ['close'], skip_paused=True, df=False)
        close = np.array(hist['close'], dtype=float)
        if len(close) < g.ema_touch_lookback + 2:
            return 0.0
        ema10 = talib.EMA(close, timeperiod=10)
        bonus = 0.0
        for i in range(-g.ema_touch_lookback, 0):
            if close[i] <= ema10[i] * 1.01:
                if close[i] >= ema10[i]:
                    bonus = max(bonus, float(g.ema_touch_bonus_above))
                else:
                    bonus = max(bonus, float(g.ema_touch_bonus_below))
        return bonus
    except Exception:
        return 0.0


def _apply_momentum_score(base_score, stock, context, include_today=False):
    """形态基础分 + 昨/今动量分 + EMA10 回踩加分"""
    y = _get_yesterday_return_pct(stock, context) * g.momentum_factor_yesterday
    t = (_get_today_return_pct(stock, context) * g.momentum_factor_today
         if include_today else 0.0)
    ema_bonus = _get_ema10_touch_bonus(stock, context)
    return base_score + y + t + ema_bonus, y, t, ema_bonus


def _log_momentum_stats(pool, label):
    """汇总动量加减分：跌为负分，涨为正分"""
    if not pool:
        return
    y_list = [item['yesterday_mom'] for item in pool]
    t_list = [item['today_mom'] for item in pool]
    m_list = [item['momentum'] for item in pool]
    e_list = [item.get('ema_bonus', 0) for item in pool]
    y_neg = sum(1 for v in y_list if v < 0)
    t_neg = sum(1 for v in t_list if v < 0)
    m_neg = sum(1 for v in m_list if v < 0)
    e_pos = sum(1 for v in e_list if v > 0)
    log.info(f"📉 {label}动量统计: {len(pool)}只 | "
             f"昨扣分{y_neg}只(均{y_list and sum(y_list)/len(y_list):+.2f}) "
             f"今扣分{t_neg}只(均{t_list and sum(t_list)/len(t_list):+.2f}) | "
             f"合计动量负分{m_neg}只 区间[{min(m_list):+.1f},{max(m_list):+.1f}] | "
             f"EMA加分{e_pos}只")


def _refresh_today_stocks_momentum(context):
    """10:00 买入前刷新今日动量并重新排序"""
    for item in g.today_stocks:
        final, y, t, ema_bonus = _apply_momentum_score(
            item['base_score'], item['code'], context, include_today=True)
        item['yesterday_mom'] = y
        item['today_mom'] = t
        item['ema_bonus'] = ema_bonus
        item['momentum'] = y + t + ema_bonus
        item['score'] = final
    g.today_stocks.sort(key=lambda x: -x['score'])


def _check_stop_loss(context, market_score, label=''):
    for stock in list(context.portfolio.positions.keys()):
        position = context.portfolio.positions[stock]
        if position.total_amount == 0:
            continue
        current_data = get_current_data()
        if current_data[stock].paused:
            log.info(f"[止损跳过{label}] {_stock_label(stock)} 停牌")
            continue
        current_price = current_data[stock].last_price
        if not np.isfinite(current_price) or current_price <= 0:
            log.info(f"[止损跳过{label}] {_stock_label(stock)} 价格无效")
            continue
        cost = position.avg_cost
        pnl_ratio = (current_price - cost) / cost
        threshold, d = _explain_stop_threshold(stock, context, market_score)
        if g.analysis_log:
            _log_stop_threshold(stock, context, market_score, label)
        if pnl_ratio <= -threshold:
            reason = f"止损-{-threshold*100:.1f}%"
            if d['atr_part'] is not None and threshold == d['atr_part']:
                reason = f"ATR止损-{-threshold*100:.1f}%"
            elif d['bear'] and threshold == d['after_bear']:
                reason = f"熊市止损-{-threshold*100:.1f}%"
            _safe_order_target_value(stock, 0, current_price, 'sell', context)
            _log_trade('SELL', stock, context, reason, pnl_ratio,
                       f"成本{cost:.2f} 现价{current_price:.2f}")
            _cleanup_position_state(stock)


def _check_profit_trailing_all(context, label=''):
    for stock in list(context.portfolio.positions.keys()):
        position = context.portfolio.positions[stock]
        if position.total_amount == 0:
            continue
        current_data = get_current_data()
        if current_data[stock].paused:
            continue
        current_price = current_data[stock].last_price
        if not np.isfinite(current_price) or current_price <= 0:
            continue
        cost = position.avg_cost
        pnl_ratio = (current_price - cost) / cost
        _apply_profit_trailing(stock, position, current_price, pnl_ratio, context, label)


