def _is_st_or_delist(stock, current_data=None):
    """排除 ST / *ST / 退市风险股（is_st 标志 + 名称）"""
    if current_data is None:
        current_data = get_current_data()
    cd = current_data[stock]
    if cd.is_st:
        return True
    info = get_security_info(stock)
    if info is None:
        return True
    name = (info.display_name or '') + (getattr(cd, 'name', '') or '')
    for kw in ('ST', '※ST', '*ST', '退'):
        if kw in name:
            return True
    return False

def get_market_score(context, with_detail=False):
    """
    大盘趋势评分（来自趋势跟踪策略）
    返回0-100分，用于仓位管理
    """
    df = get_price('000001.XSHG', count=60, end_date=context.previous_date, fields='close')
    if len(df) < 60:
        detail = {'score': 50, 'close': 0, 'ma20': 0, 'ma60': 0, 'ret20': 0, 'base': 50}
        return (50, detail) if with_detail else 50

    close = df['close']
    ma20 = close.rolling(20).mean().iloc[-1]
    ma60 = close.rolling(60).mean().iloc[-1]
    current = close.iloc[-1]

    if current > ma20 > ma60:
        base_score = 80
    elif current > ma20:
        base_score = 60
    elif current > ma60:
        base_score = 40
    else:
        base_score = 30

    ret20 = (current / close.iloc[-21] - 1) if len(close) >= 21 else 0
    score = base_score
    if ret20 > 0.05:
        score = min(90, score + 10)
    elif ret20 < -0.05:
        score = max(20, score - 10)

    detail = {
        'score': score, 'close': current, 'ma20': ma20, 'ma60': ma60,
        'ret20': ret20, 'base': base_score
    }
    return (score, detail) if with_detail else score

def calculate_position_ratio(market_score):
    """
    根据大盘评分计算仓位比例
    """
    if market_score >= 70:
        return 1.0   # 满仓
    elif market_score >= 55:
        return 0.8   # 8成仓
    elif market_score >= 40:
        return 0.6   # 6成仓
    elif market_score >= 25:
        return 0.4   # 4成仓
    else:
        return 0.2   # 2成仓

def before_trading_start(context):
    """盘前选股，计算持仓股票的死叉信号"""
    g._daily_sells = []
    g._daily_buys = []

    log.info("=" * 60)
    log.info(f"📊 价格行为选股执行中 · {g.strategy_tag}")
    log.info("=" * 60)

    g.sold_today.clear()

    stock_pool, stats = get_canslim_pool(context)
    log.info(f"📈 选股漏斗: 基本面{stats['fundamental']} → 合规{stats['filtered_exclude']} → "
             f"技术面{stats['technical_pass']} "
             f"(52周回撤剔除{stats.get('corr_excluded', 0)} "
             f"MA200剔除{stats.get('ma200_excluded', 0)} "
             f"低价剔除{stats.get('price_excluded', 0)} "
             f"成交额剔除{stats.get('volume_excluded', 0)} "
             f"历史不足{stats.get('hist_short', 0)})")

    final_pool = []
    stage_reject = 0
    stage_errors = 0
    for stock in stock_pool:
        try:
            stage, score, setup = detect_cycle_stage(stock, context)
            if stage == 2 and setup in ['wedge_pop', 'ema_crossback', 'base_break']:
                final_score, y_mom, t_mom, ema_bonus = _apply_momentum_score(
                    score, stock, context, include_today=False)
                final_pool.append({
                    'code': stock,
                    'name': get_security_info(stock).display_name,
                    'base_score': score,
                    'setup': setup,
                    'yesterday_mom': y_mom,
                    'today_mom': t_mom,
                    'ema_bonus': ema_bonus,
                    'momentum': y_mom + t_mom + ema_bonus,
                    'score': final_score
                })
            else:
                stage_reject += 1
        except Exception as e:
            stage_errors += 1
            if g.debug_mode:
                log.warn(f"处理 {stock} 时出错: {e}")
            continue

