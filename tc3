def initialize(context):
    """初始化策略"""
    # 设置基准
    set_benchmark('000300.XSHG')
    set_option('use_real_price', True)
    set_order_cost(OrderCost(
        open_tax=0,
        close_tax=0.001,
        open_commission=0.00025,
        close_commission=0.00025,
        close_today_commission=0,
        min_commission=5
    ), type='stock')
    set_slippage(FixedSlippage(0.001))ß

    # ==================== 仓位管理参数（来自趋势跟踪策略） ====================
    g.max_holdings = 5                     # 最大持仓数量
    g.position_size = 0.8                 # 基础仓位比例

    # ==================== 选股参数（来自价格行为策略） ====================
    g.max_correction_from_high = 0.30      # 允许从52周高点回撤不超过30%
