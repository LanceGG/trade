    g.daily_nav = []                       # 净值记录
    g.break_upper_count = {}               # 记录每只股票跌破上轨下沿的天数
    g.position_high = {}                   # 持仓最高价（盈利回撤止盈）
    g.trail_half_done = {}                 # 是否已执行过半仓减仓

    # ==================== 分析日志 ====================
    g.strategy_tag = 'tc3'
    g.analysis_log = True                  # 结构化分析日志（巡检/漏斗/跟踪预警）
    g._daily_sells = []                    # [(stock, reason, pnl_ratio)]
    g._daily_buys = []                     # [(stock, score, setup)]

    # ==================== 定时运行 ====================
    run_daily(before_trading_start, time='07:30')
    run_daily(market_open_trade, time='10:00')
    run_daily(afternoon_stop_check, time='14:30')
